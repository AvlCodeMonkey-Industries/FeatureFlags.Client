# Auto detect text files and perform LF normalization
*          text=auto

*.cs       text diff=csharp eol=crlf
*.cshtml   text diff=html eol=crlf
*.csx      text diff=csharp eol=crlf
*.sln      text eol=crlf
*.slnx     text eol=crlf
*.csproj   text eol=crlf
*.resx     text eol=crlf
*.config   text eol=crlf
*.md       text eol=crlf

*.js       text eol=crlf
*.mjs      text eol=crlf
*.json     text eol=crlf
*.css      text eol=crlf
